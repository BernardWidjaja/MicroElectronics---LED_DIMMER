-- ============================================================
-- LPF Constraint File — One-Key LED Dimmer
-- Target: Lattice XP2-17 (LFXP2-17E, TQFP-208), XP2-17 FPGA Board
-- Maps the exact port names of entity led_dimmer (design.vhd)
-- to the physical FPGA sites listed in the board reference doc.
-- ============================================================

-- Global default I/O standard for every pin (per board reference, Sec. 1)
IOBUF ALLPORTS IO_TYPE=LVCMOS33;

-- ------------------------------------------------------------
-- Clock input
-- 24 MHz on-board oscillator (board reference, Sec. 3)
-- ------------------------------------------------------------
LOCATE COMP "clk_in" SITE "53";
IOBUF PORT "clk_in" IO_TYPE=LVCMOS33 PULLMODE=NONE;
FREQUENCY NET "clk_in" 24.000000 MHz;

-- ------------------------------------------------------------
-- Push button S1 (board reference, Sec. 4)
-- button_no_1 = normally-open contact (used by the design)
-- button_nc_1 = normally-closed contact (entity port exists but
--               unused inside the architecture)
-- ------------------------------------------------------------
LOCATE COMP "button_no_1" SITE "17";
LOCATE COMP "button_nc_1" SITE "18";

-- ------------------------------------------------------------
-- LED row — all 8 LEDs driven by the same PWM signal
-- (board reference, Sec. 6)
-- ------------------------------------------------------------
LOCATE COMP "led_0" SITE "93";
LOCATE COMP "led_1" SITE "94";
LOCATE COMP "led_2" SITE "97";
LOCATE COMP "led_3" SITE "98";
LOCATE COMP "led_4" SITE "101";
LOCATE COMP "led_5" SITE "102";
LOCATE COMP "led_6" SITE "103";
LOCATE COMP "led_7" SITE "104";

-- ------------------------------------------------------------
-- 7-Segment Display — LEFT digit (lamp on/off indicator)
-- (board reference, Sec. 7 — "Left digit FPGA site" column)
-- dp is not used by this design and is left unconnected.
-- ------------------------------------------------------------
LOCATE COMP "seg_left_a" SITE "121";
LOCATE COMP "seg_left_b" SITE "118";
LOCATE COMP "seg_left_c" SITE "120";
LOCATE COMP "seg_left_d" SITE "124";
LOCATE COMP "seg_left_e" SITE "136";
LOCATE COMP "seg_left_f" SITE "122";
LOCATE COMP "seg_left_g" SITE "134";

-- ------------------------------------------------------------
-- 7-Segment Display — RIGHT digit (brightness level 0-4)
-- (board reference, Sec. 7 — "Right digit FPGA site" column)
-- dp is not used by this design and is left unconnected.
-- ------------------------------------------------------------
LOCATE COMP "seg_right_a" SITE "111";
LOCATE COMP "seg_right_b" SITE "106";
LOCATE COMP "seg_right_c" SITE "110";
LOCATE COMP "seg_right_d" SITE "113";
LOCATE COMP "seg_right_e" SITE "115";
LOCATE COMP "seg_right_f" SITE "112";
LOCATE COMP "seg_right_g" SITE "114";

-- ------------------------------------------------------------
-- PMOD C connector — oscilloscope-observable debug outputs
-- (board reference, Sec. 10 / Connectivity table)
-- pin 1: pwm_out          pin 2: btn_debounced
-- pin 3: short_press      pin 4: long_press
-- ------------------------------------------------------------
LOCATE COMP "pmod_c_pin_1" SITE "72";
LOCATE COMP "pmod_c_pin_2" SITE "68";
LOCATE COMP "pmod_c_pin_3" SITE "66";
LOCATE COMP "pmod_c_pin_4" SITE "64";
